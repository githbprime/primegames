<!DOCTYPE html>
<html>
<head>
    <title>Google</title>
</head>
<body>
    <script>
        // CHANGE THIS TO THE GAME'S ACTUAL URL
        const gameUrl = "truffled.lol/games/YOMIHustle/";

        function launch() {
            const win = window.open('about:blank', '_blank');
            if (win) {
                win.document.body.style.margin = '0';
                win.document.body.style.height = '100vh';
                win.document.body.style.background = '#000';
                const ifr = win.document.createElement('iframe');
                ifr.style.border = 'none';
                ifr.style.width = '100%';
                ifr.style.height = '100%';
                ifr.src = gameUrl;
                win.document.body.appendChild(ifr);
                
                // Redirect the original "Menu" tab to Google to hide evidence
                window.location.replace("https://google.com");
            } else {
                document.body.innerHTML = "<h1>Please allow pop-ups for this site.</h1>";
            }
        }
        
        launch();
    </script>
</body>
</html>
